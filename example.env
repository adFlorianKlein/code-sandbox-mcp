# -----------------------------------------------------------------------
# MCP Server
# -----------------------------------------------------------------------
MCP_TRANSPORT_TYPE=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000

# -----------------------------------------------------------------------
# Git credentials
# Used by git_clone_repo, git_commit, and git_push as fallback when the
# tool arguments are not explicitly provided.
# -----------------------------------------------------------------------
GIT_TOKEN=your_personal_access_token
GIT_USER_NAME=your_username
GIT_USER_EMAIL=your_email@example.com

# -----------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------
LOG_PATH=/app/logs/mcp_tools.jsonl
LOG_MAX_ENTRIES=1000

# -----------------------------------------------------------------------
# Build / run_command
# -----------------------------------------------------------------------
# Maximum seconds a run_command call may run before it is killed.
RUN_COMMAND_TIMEOUT=120
